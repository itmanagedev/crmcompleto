# ==========================================
# Configurações do Banco de Dados (PostgreSQL)
# ==========================================
# URL de conexão no formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://crm_user:crm_password@crm-db:5432/crm_database?schema=public"

# ==========================================
# Configurações de Cache e Filas (Redis)
# ==========================================
# URL de conexão com o Redis
REDIS_URL="redis://crm-redis:6379"

# ==========================================
# Configurações de Autenticação (NextAuth)
# ==========================================
# URL base da aplicação (usada pelo NextAuth para callbacks)
NEXTAUTH_URL="http://localhost:3000"
# Chave secreta para assinar os tokens JWT (Gere uma usando `openssl rand -base64 32`)
NEXTAUTH_SECRET="sua_chave_secreta_super_segura_aqui"

# ==========================================
# Provedores de Login Social (Google OAuth)
# ==========================================
# Credenciais obtidas no Google Cloud Console
GOOGLE_CLIENT_ID="seu_google_client_id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="seu_google_client_secret"

# ==========================================
# Configurações de E-mail (SMTP)
# ==========================================
# Servidor SMTP (ex: smtp.sendgrid.net, smtp.gmail.com)
SMTP_HOST="smtp.mailtrap.io"
# Porta do servidor SMTP (geralmente 587 ou 465)
SMTP_PORT="2525"
# Usuário de autenticação SMTP
SMTP_USER="seu_usuario_smtp"
# Senha de autenticação SMTP
SMTP_PASS="sua_senha_smtp"
# E-mail remetente padrão
SMTP_FROM="CRM Pro <nao-responda@crmpro.com>"

# ==========================================
# Variáveis Públicas da Aplicação
# ==========================================
# URL pública da aplicação (usada no frontend)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Nome da aplicação
NEXT_PUBLIC_APP_NAME="CRM Pro"

# ==========================================
# Configurações do pgAdmin (Opcional)
# ==========================================
# E-mail de acesso ao painel do pgAdmin (porta 5050)
PGADMIN_EMAIL="admin@crmpro.com"
# Senha de acesso ao painel do pgAdmin
PGADMIN_PASSWORD="admin"
